{
	"name": "2025-3e-IDLGS",
	"private": true,
	"version": "1.0.0",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . ; eslint src/",
		"format": "prettier --write .",
		"db:start": "docker compose up",
		"db:push": "drizzle-kit push",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"db:studio": "drizzle-kit studio",
		"sveltekit": "npx svelte-kit sync && npx paraglide-js compile --project ./project.inlang --outdir ./src/lib/paraglide && npx svelte-check --tsconfig ./../tsconfig.json --workspace src/",
		"cloc": "npx cloc src/ --not-match-d=\"lib/paraglide\"",
		"i18n": "npx paraglide-js compile --project ./project.inlang --outdir ./src/lib/paraglide"
	},
	"devDependencies": {
		"@eslint/compat": "^2.0.2",
		"@eslint/js": "^9.39.2",
		"@inlang/paraglide-js": "^2.10.0",
		"@sveltejs/adapter-node": "^5.5.2",
		"@sveltejs/kit": "^2.50.2",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@tailwindcss/forms": "^0.5.11",
		"@tailwindcss/typography": "^0.5.19",
		"@tailwindcss/vite": "^4.1.18",
		"@types/markdown-it": "^14.1.2",
		"@types/node": "^24.12.2",
		"@types/nodemailer": "^8.0.0",
		"cloc": "^2.6.0-cloc",
		"drizzle-kit": "^0.31.8",
		"drizzle-orm": "^0.45.1",
		"eslint": "^9.39.4",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.14.0",
		"globals": "^17.3.0",
		"postgres": "^3.4.8",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.4.1",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"svelte": "^5.51.0",
		"svelte-check": "^4.4.2",
		"tailwindcss": "^4.1.18",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.54.0",
		"vite": "^7.3.1"
	},
	"dependencies": {
		"@google/model-viewer": "^4.2.0",
		"chart.js": "^4.5.1",
		"cloudinary": "^2.9.0",
		"colord": "^2.9.3",
		"function-plot": "^1.25.4",
		"fuse.js": "^7.3.0",
		"highlight.js": "^11.11.1",
		"highlighter.js": "^1.0.0",
		"katex": "^0.16.45",
		"markdown-it": "^14.1.1",
		"node-calls-python": "^1.11.1",
		"node-gyp": "^12.2.0",
		"nodemailer": "^8.0.7",
		"remixicon": "^4.9.1",
		"vite-plugin-env-compatible": "^2.0.1"
	}
}
