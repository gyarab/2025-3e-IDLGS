        "type": {
          "name": "type",
          "value": "\"exercise\".\"type\" IN ('CRS', 'CRW', 'DEF', 'GRP', 'GEO', 'EXT')"
        },
        "exerciseTypeData": {
          "name": "exerciseTypeData",
          "value": "(type = 'CRS' AND crs IS NOT NULL AND \"crosswordDataId\" IS NULL AND def IS NULL AND grp IS NULL AND geo IS NULL AND ext IS NULL) OR\n\t\t\t(type = 'CRW' AND crw IS NOT NULL AND \"crosswordDataId\" IS NULL AND def IS NULL AND grp IS NULL AND geo IS NULL AND ext IS NULL) OR\n\t\t\t(type = 'DEF' AND def IS NOT NULL AND \"crosswordDataId\" IS NULL AND crs IS NULL AND crw IS NULL AND grp IS NULL AND geo IS NULL AND ext IS NULL) OR\n\t\t\t(type = 'GRP' AND grp IS NOT NULL AND \"crosswordDataId\" IS NULL AND crs IS NULL AND crw IS NULL AND def IS NULL AND geo IS NULL AND ext IS NULL) OR\n\t\t\t(type = 'GEO' AND geo IS NOT NULL AND \"crosswordDataId\" IS NULL AND crs IS NULL AND crw IS NULL AND def IS NULL AND grp IS NULL AND ext IS NULL) OR\n\t\t\t(type = 'EXT' AND ext IS NOT NULL AND \"crosswordDataId\" IS NULL AND crs IS NULL AND crw IS NULL AND def IS NULL AND grp IS NULL AND geo IS NULL) OR\n\t\t\t(type = 'CRW' AND \"crosswordDataId\" IS NOT NULL AND crs IS NULL AND def IS NULL AND grp IS NULL AND geo IS NULL AND ext IS NULL)\n\t\t\t"
        },
        "colorValues": {
          "name": "colorValues",
          "value": "(\"backgroundColorR\" >= 0 AND \"backgroundColorR\" <= 255) AND\n\t\t\t(\"backgroundColorG\" >= 0 AND \"backgroundColorG\" <= 255) AND\n\t\t\t(\"backgroundColorB\" >= 0 AND \"backgroundColorB\" <= 255) AND\n\t\t\t(\"foregroundColorR\" >= 0 AND \"foregroundColorR\" <= 255) AND\n\t\t\t(\"foregroundColorG\" >= 0 AND \"foregroundColorG\" <= 255) AND\n\t\t\t(\"foregroundColorB\" >= 0 AND \"foregroundColorB\" <= 255)"
        }
